# Server Configuration
NODE_ENV=development
PORT=3001

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=your_database_user
DB_PASSWORD=your_secure_password_here
DB_DATABASE=your_database_name
DB_CONNECTION_LIMIT=10
TENANT_ID=1

# Prisma Database URL (auto-generated from above, or set directly)
DATABASE_URL="mysql://${DB_USERNAME}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_DATABASE}"

# JWT Configuration (IMPORTANT: Generate strong random secrets for production!)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars

# Redis Configuration (for queues)
REDIS_URL=redis://localhost:6379

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8080

# Additional CORS origins (comma-separated, optional)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://yourdomain.com

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760

# External Services
# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=curriculum-files

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Logging
LOG_LEVEL=info

# Database Timezone (default: UTC)
DB_TIMEZONE=+00:00

# OCR Service Configuration
OCR_SERVICE_URL=http://localhost:8000

# FFmpeg Path (for video/audio processing)
# Leave empty to use system PATH, or specify custom path
FFMPEG_PATH=

# Whisper Configuration (for audio transcription)
WHISPER_ENABLED=false

# AI Service (optional)
AI_SERVICE_URL=https://api.openai.com/v1
AI_SERVICE_KEY=your-openai-key

# Gemini API (for AI features)
GEMINI_API_KEY=your-gemini-api-key-here

# Webhook Secret (for external integrations)
WEBHOOK_SECRET=your-webhook-secret
