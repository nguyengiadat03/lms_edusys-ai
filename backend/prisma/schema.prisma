generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model activity_participation {
  id                 BigInt                                    @id @default(autoincrement()) @db.UnsignedBigInt
  class_session_id   BigInt                                    @db.UnsignedBigInt
  student_user_id    BigInt                                    @db.UnsignedBigInt
  participation_type activity_participation_participation_type @default(activity)
  reference_id       BigInt?                                   @db.UnsignedBigInt
  score              Decimal?                                  @db.Decimal(6, 2)
  notes              String?                                   @db.VarChar(255)
  created_at         DateTime?                                 @default(now()) @db.Timestamp(0)
  class_sessions     class_sessions                            @relation(fields: [class_session_id], references: [id], onDelete: Cascade, map: "activity_participation_ibfk_1")
  users              users                                     @relation(fields: [student_user_id], references: [id], onDelete: Cascade, map: "activity_participation_ibfk_2")

  @@index([class_session_id, student_user_id], map: "idx_ap_session_student")
  @@index([student_user_id], map: "student_user_id")
}

model activity_response_files {
  id                 BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  response_id        BigInt             @db.UnsignedBigInt
  document_id        BigInt?            @db.UnsignedBigInt
  url                String?            @db.Text
  mime_type          String?            @db.VarChar(128)
  file_size          BigInt?            @db.UnsignedBigInt
  created_at         DateTime?          @default(now()) @db.Timestamp(0)
  activity_responses activity_responses @relation(fields: [response_id], references: [id], onDelete: Cascade, map: "activity_response_files_ibfk_1")
  documents          documents?         @relation(fields: [document_id], references: [id], map: "activity_response_files_ibfk_2")

  @@index([document_id], map: "document_id")
  @@index([response_id], map: "idx_arf_response")
}

model activity_responses {
  id                      BigInt                    @id @default(autoincrement()) @db.UnsignedBigInt
  session_activity_id     BigInt                    @db.UnsignedBigInt
  user_id                 BigInt                    @db.UnsignedBigInt
  response_json           Json?
  score                   Decimal?                  @db.Decimal(8, 2)
  feedback                String?                   @db.Text
  created_at              DateTime?                 @default(now()) @db.Timestamp(0)
  updated_at              DateTime?                 @default(now()) @db.Timestamp(0)
  activity_response_files activity_response_files[]
  session_activities      session_activities        @relation(fields: [session_activity_id], references: [id], onDelete: Cascade, map: "activity_responses_ibfk_1")
  users                   users                     @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "activity_responses_ibfk_2")

  @@unique([session_activity_id, user_id], map: "uk_ar_unique")
  @@index([user_id], map: "idx_ar_user")
}

model activity_template_assets {
  id                 BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  template_id        BigInt             @db.UnsignedBigInt
  document_id        BigInt?            @db.UnsignedBigInt
  url                String?            @db.Text
  notes              String?            @db.VarChar(255)
  activity_templates activity_templates @relation(fields: [template_id], references: [id], onDelete: Cascade, map: "activity_template_assets_ibfk_1")
  documents          documents?         @relation(fields: [document_id], references: [id], map: "activity_template_assets_ibfk_2")

  @@index([document_id], map: "document_id")
  @@index([template_id], map: "idx_ataa_template")
}

model activity_template_roles {
  id                 BigInt             @id @default(autoincrement()) @db.UnsignedBigInt
  template_id        BigInt             @db.UnsignedBigInt
  role_name          String             @db.VarChar(128)
  description        String?            @db.Text
  order_index        Int?               @default(0) @db.UnsignedInt
  activity_templates activity_templates @relation(fields: [template_id], references: [id], onDelete: Cascade, map: "activity_template_roles_ibfk_1")

  @@index([template_id], map: "idx_atr_template")
}

model activity_template_steps {
  id                 BigInt                            @id @default(autoincrement()) @db.UnsignedBigInt
  template_id        BigInt                            @db.UnsignedBigInt
  step_type          activity_template_steps_step_type @default(other)
  title              String?                           @db.VarChar(255)
  description        String?                           @db.Text
  duration_minutes   Int?                              @db.UnsignedInt
  order_index        Int?                              @default(0) @db.UnsignedInt
  activity_templates activity_templates                @relation(fields: [template_id], references: [id], onDelete: Cascade, map: "activity_template_steps_ibfk_1")

  @@index([template_id, order_index], map: "idx_ats_template_order")
}

model activity_template_tags {
  template_id        BigInt             @db.UnsignedBigInt
  tag_id             BigInt             @db.UnsignedBigInt
  activity_templates activity_templates @relation(fields: [template_id], references: [id], onDelete: Cascade, map: "activity_template_tags_ibfk_1")
  tags               tags               @relation(fields: [tag_id], references: [id], onDelete: Cascade, map: "activity_template_tags_ibfk_2")

  @@id([template_id, tag_id])
  @@index([tag_id], map: "tag_id")
}

model activity_templates {
  id                                            BigInt                           @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id                                     BigInt                           @db.UnsignedBigInt
  code                                          String                           @db.VarChar(64)
  title                                         String                           @db.VarChar(255)
  activity_kind                                 activity_templates_activity_kind @default(other)
  phase_hint                                    activity_templates_phase_hint?
  level                                         String?                          @db.VarChar(32)
  skill                                         activity_templates_skill?
  duration_minutes                              Int?                             @db.UnsignedInt
  objectives                                    Json?
  instructions                                  String?                          @db.Text
  configuration                                 Json?
  owner_user_id                                 BigInt?                          @db.UnsignedBigInt
  visibility                                    activity_templates_visibility    @default(tenant)
  created_by                                    BigInt?                          @db.UnsignedBigInt
  updated_by                                    BigInt?                          @db.UnsignedBigInt
  created_at                                    DateTime?                        @default(now()) @db.Timestamp(0)
  updated_at                                    DateTime?                        @default(now()) @db.Timestamp(0)
  activity_template_assets                      activity_template_assets[]
  activity_template_roles                       activity_template_roles[]
  activity_template_steps                       activity_template_steps[]
  activity_template_tags                        activity_template_tags[]
  tenants                                       tenants                          @relation(fields: [tenant_id], references: [id], onDelete: Cascade, map: "activity_templates_ibfk_1")
  users_activity_templates_owner_user_idTousers users?                           @relation("activity_templates_owner_user_idTousers", fields: [owner_user_id], references: [id], map: "activity_templates_ibfk_2")
  users_activity_templates_created_byTousers    users?                           @relation("activity_templates_created_byTousers", fields: [created_by], references: [id], map: "activity_templates_ibfk_3")
  users_activity_templates_updated_byTousers    users?                           @relation("activity_templates_updated_byTousers", fields: [updated_by], references: [id], map: "activity_templates_ibfk_4")
  session_activity_instances                    session_activity_instances[]
  unit_activity_links                           unit_activity_links[]

  @@unique([tenant_id, code], map: "uk_activity_tpl_code")
  @@index([created_by], map: "created_by")
  @@index([activity_kind], map: "idx_act_tpl_kind")
  @@index([skill], map: "idx_act_tpl_skill")
  @@index([owner_user_id], map: "owner_user_id")
  @@index([updated_by], map: "updated_by")
}

model applications {
  id                  BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id           BigInt               @db.UnsignedBigInt
  lead_id             BigInt?              @db.UnsignedBigInt
  student_user_id     BigInt?              @db.UnsignedBigInt
  desired_program_id  BigInt?              @db.UnsignedBigInt
  status              applications_status? @default(submitted)
  submitted_at        DateTime?            @db.Timestamp(0)
  decision_at         DateTime?            @db.Timestamp(0)
  notes               String?              @db.Text
  created_at          DateTime?            @default(now()) @db.Timestamp(0)
  updated_at          DateTime?            @default(now()) @db.Timestamp(0)
  tenants             tenants              @relation(fields: [tenant_id], references: [id], onDelete: Cascade, map: "applications_ibfk_1")
  leads               leads?               @relation(fields: [lead_id], references: [id], map: "applications_ibfk_2")
  users               users?               @relation(fields: [student_user_id], references: [id], map: "applications_ibfk_3")
  program_definitions program_definitions? @relation(fields: [desired_program_id], references: [id], map: "applications_ibfk_4")
  contracts           contracts[]

  @@index([desired_program_id], map: "desired_program_id")
  @@index([tenant_id, status], map: "idx_applications_tenant_status")
  @@index([lead_id], map: "lead_id")
  @@index([student_user_id], map: "student_user_id")
}

model approvals {
  id                                          BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id                                   BigInt                        @db.UnsignedBigInt
  version_id                                  BigInt                        @db.UnsignedBigInt
  requested_by                                BigInt?                       @db.UnsignedBigInt
  assigned_reviewer_id                        BigInt?                       @db.UnsignedBigInt
  status                                      approvals_status              @default(requested)
  priority                                    approvals_priority            @default(normal)
  review_deadline                             DateTime?                     @db.Timestamp(0)
  decision                                    String?                       @db.Text
  decision_made_by                            BigInt?                       @db.UnsignedBigInt
  decision_made_at                            DateTime?                     @db.Timestamp(0)
  escalation_reason                           String?                       @db.Text
  escalated_to                                BigInt?                       @db.UnsignedBigInt
  escalated_at                                DateTime?                     @db.Timestamp(0)
  created_at                                  DateTime                      @default(now()) @db.Timestamp(0)
  updated_at                                  DateTime                      @default(now()) @db.Timestamp(0)
  users_approvals_assigned_reviewer_idTousers users?                        @relation("approvals_assigned_reviewer_idTousers", fields: [assigned_reviewer_id], references: [id])
  users_approvals_decision_made_byTousers     users?                        @relation("approvals_decision_made_byTousers", fields: [decision_made_by], references: [id])
  users_approvals_escalated_toTousers         users?                        @relation("approvals_escalated_toTousers", fields: [escalated_to], references: [id])
  users_approvals_requested_byTousers         users?                        @relation("approvals_requested_byTousers", fields: [requested_by], references: [id])
  tenants                                     tenants                       @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  curriculum_framework_versions               curriculum_framework_versions @relation(fields: [version_id], references: [id], onDelete: Cascade)

  @@index([assigned_reviewer_id])
  @@index([decision_made_by], map: "approvals_decision_made_by_fkey")
  @@index([escalated_to], map: "approvals_escalated_to_fkey")
  @@index([priority])
  @@index([requested_by], map: "approvals_requested_by_fkey")
  @@index([review_deadline])
  @@index([tenant_id], map: "approvals_tenant_id_fkey")
  @@index([version_id, status])
}

model assessment_items {
  id            BigInt                      @id @default(autoincrement()) @db.UnsignedBigInt
  assessment_id BigInt                      @db.UnsignedBigInt
  item_type     assessment_items_item_type? @default(question)
  title         String?                     @db.VarChar(255)
  max_score     Decimal?                    @default(0.00) @db.Decimal(8, 2)
  order_index   Int?                        @default(0) @db.UnsignedInt
  payload       Json?
  assessments   assessments                 @relation(fields: [assessment_id], references: [id], onDelete: Cascade, map: "assessment_items_ibfk_1")

  @@index([assessment_id], map: "idx_ai_assessment")
}

model assessment_results {
  id                                              BigInt          @id @default(autoincrement()) @db.UnsignedBigInt
  assessment_id                                   BigInt          @db.UnsignedBigInt
  student_user_id                                 BigInt          @db.UnsignedBigInt
  score                                           Decimal?        @db.Decimal(8, 2)
  details                                         Json?
  graded_at                                       DateTime?       @db.Timestamp(0)
  graded_by                                       BigInt?         @db.UnsignedBigInt
  assessments                                     assessments     @relation(fields: [assessment_id], references: [id], onDelete: Cascade, map: "assessment_results_ibfk_1")
  users_assessment_results_student_user_idTousers users           @relation("assessment_results_student_user_idTousers", fields: [student_user_id], references: [id], onDelete: Cascade, map: "assessment_results_ibfk_2")
  users_assessment_results_graded_byTousers       users?          @relation("assessment_results_graded_byTousers", fields: [graded_by], references: [id], map: "assessment_results_ibfk_3")
  rubric_scores                                   rubric_scores[]

  @@unique([assessment_id, student_user_id], map: "uk_assessment_student")
  @@index([graded_by], map: "graded_by")
  @@index([student_user_id], map: "student_user_id")
}

model assessments {
  id                 BigInt                       @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id          BigInt                       @db.UnsignedBigInt
  class_id           BigInt?                      @db.UnsignedBigInt
  title              String                       @db.VarChar(255)
  assessment_type    assessments_assessment_type? @default(other)
  total_score        Decimal?                     @default(100.00) @db.Decimal(8, 2)
  due_at             DateTime?                    @db.Timestamp(0)
  created_by         BigInt?                      @db.UnsignedBigInt
  created_at         DateTime?                    @default(now()) @db.Timestamp(0)
  updated_at         DateTime?                    @default(now()) @db.Timestamp(0)
  assessment_items   assessment_items[]
  assessment_results assessment_results[]
  tenants            tenants                      @relation(fields: [tenant_id], references: [id], onDelete: Cascade, map: "assessments_ibfk_1")
  classes            classes?                     @relation(fields: [class_id], references: [id], map: "assessments_ibfk_2")
  users              users?                       @relation(fields: [created_by], references: [id], map: "assessments_ibfk_3")

  @@index([class_id], map: "class_id")
  @@index([created_by], map: "created_by")
  @@index([tenant_id], map: "idx_assessments_tenant")
}

model assignment_attachments {
  id            BigInt      @id @default(autoincrement()) @db.UnsignedBigInt
  assignment_id BigInt      @db.UnsignedBigInt
  document_id   BigInt      @db.UnsignedBigInt
  created_at    DateTime?   @default(now()) @db.Timestamp(0)
  assignments   assignments @relation(fields: [assignment_id], references: [id], onDelete: Cascade, map: "assignment_attachments_ibfk_1")
  documents     documents   @relation(fields: [document_id], references: [id], onDelete: Cascade, map: "assignment_attachments_ibfk_2")

  @@index([document_id], map: "document_id")
  @@index([assignment_id], map: "idx_aatt_assignment")
}

model assignment_collection_items {
  id                     BigInt                 @id @default(autoincrement()) @db.UnsignedBigInt
  collection_id          BigInt                 @db.UnsignedBigInt
  assignment_id          BigInt                 @db.UnsignedBigInt
  added_at               DateTime?              @default(now()) @db.Timestamp(0)
  assignment_collections assignment_collections @relation(fields: [collection_id], references: [id], onDelete: Cascade, map: "assignment_collection_items_ibfk_1")
  assignments            assignments            @relation(fields: [assignment_id], references: [id], onDelete: Cascade, map: "assignment_collection_items_ibfk_2")

  @@unique([collection_id, assignment_id], map: "uk_aci_unique")
  @@index([assignment_id], map: "assignment_id")
}

model assignment_collections {
  id                          BigInt                            @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id                   BigInt                            @db.UnsignedBigInt
  owner_user_id               BigInt?                           @db.UnsignedBigInt
  name                        String                            @db.VarChar(255)
  visibility                  assignment_collections_visibility @default(private)
  created_at                  DateTime?                         @default(now()) @db.Timestamp(0)
  updated_at                  DateTime?                         @default(now()) @db.Timestamp(0)
  assignment_collection_items assignment_collection_items[]
  tenants                     tenants                           @relation(fields: [tenant_id], references: [id], onDelete: Cascade, map: "assignment_collections_ibfk_1")
  users                       users?                            @relation(fields: [owner_user_id], references: [id], map: "assignment_collections_ibfk_2")

  @@index([tenant_id], map: "idx_ac_tenant")
  @@index([owner_user_id], map: "owner_user_id")
}

model assignment_passages {
  id                   BigInt                   @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id            BigInt                   @db.UnsignedBigInt
  kind                 assignment_passages_kind @default(reading)
  title                String?                  @db.VarChar(255)
  content              String?                  @db.LongText
  document_id          BigInt?                  @db.UnsignedBigInt
  created_by           BigInt?                  @db.UnsignedBigInt
  created_at           DateTime?                @default(now()) @db.Timestamp(0)
  updated_at           DateTime?                @default(now()) @db.Timestamp(0)
  tenants              tenants                  @relation(fields: [tenant_id], references: [id], onDelete: Cascade, map: "assignment_passages_ibfk_1")
  documents            documents?               @relation(fields: [document_id], references: [id], map: "assignment_passages_ibfk_2")
  users                users?                   @relation(fields: [created_by], references: [id], map: "assignment_passages_ibfk_3")
  assignment_questions assignment_questions[]
  exam_items           exam_items[]

  @@index([created_by], map: "created_by")
  @@index([document_id], map: "document_id")
  @@index([tenant_id], map: "idx_ap_tenant")
}

model assignment_permissions {
  id            BigInt                              @id @default(autoincrement()) @db.UnsignedBigInt
  assignment_id BigInt                              @db.UnsignedBigInt
  subject_type  assignment_permissions_subject_type
  subject_id    BigInt                              @db.UnsignedBigInt
  permission    assignment_permissions_permission   @default(view)
  created_at    DateTime?                           @default(now()) @db.Timestamp(0)
  assignments   assignments                         @relation(fields: [assignment_id], references: [id], onDelete: Cascade, map: "assignment_permissions_ibfk_1")

  @@index([assignment_id], map: "idx_ap_assignment")
  @@index([subject_type, subject_id], map: "idx_ap_subject")
}

model assignment_practice_sessions {
  id                 BigInt                              @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id          BigInt                              @db.UnsignedBigInt
  assignment_id      BigInt                              @db.UnsignedBigInt
  user_id            BigInt                              @db.UnsignedBigInt
  status             assignment_practice_sessions_status @default(in_progress)
  started_at         DateTime                            @default(now())
  completed_at       DateTime?                           @db.Timestamp(0)
  time_spent_seconds Int                                 @default(0)
  answers            Json?
  score              Decimal?                            @db.Decimal(5, 2)
  feedback           String?                             @db.Text
  metadata           Json?
  created_at         DateTime                            @default(now())
  updated_at         DateTime
  assignments        assignments                         @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  tenants            tenants                             @relation(fields: [tenant_id], references: [id], onDelete: Cascade)
  users              users                               @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([assignment_id])
  @@index([started_at])
  @@index([status])
  @@index([tenant_id, user_id])
  @@index([user_id], map: "assignment_practice_sessions_user_id_fkey")
}

model assignment_question_media {
  id                   BigInt                         @id @default(autoincrement()) @db.UnsignedBigInt
  question_id          BigInt                         @db.UnsignedBigInt
  kind                 assignment_question_media_kind @default(image)
  document_id          BigInt?                        @db.UnsignedBigInt
  url                  String?                        @db.Text
  notes                String?                        @db.VarChar(255)
  assignment_questions assignment_questions           @relation(fields: [question_id], references: [id], onDelete: Cascade, map: "assignment_question_media_ibfk_1")
  documents            documents?                     @relation(fields: [document_id], references: [id], map: "assignment_question_media_ibfk_2")

  @@index([document_id], map: "document_id")
  @@index([question_id], map: "idx_aqm_question")
}

model assignment_question_options {
  id                   BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  question_id          BigInt               @db.UnsignedBigInt
  label                String?              @db.VarChar(16)
  content              String?              @db.Text
  is_correct           Boolean?             @default(false)
  points               Decimal?             @db.Decimal(8, 2)
  order_index          Int?                 @default(0) @db.UnsignedInt
  assignment_questions assignment_questions @relation(fields: [question_id], references: [id], onDelete: Cascade, map: "assignment_question_options_ibfk_1")

  @@index([question_id], map: "idx_aqo_question")
}

model assignment_questions {
  id                          BigInt                        @id @default(autoincrement()) @db.UnsignedBigInt
  assignment_id               BigInt                        @db.UnsignedBigInt
  type                        assignment_questions_type
  stem                        String?                       @db.Text
  passage_id                  BigInt?                       @db.UnsignedBigInt
  points                      Decimal?                      @default(1.00) @db.Decimal(8, 2)
  difficulty                  String?                       @db.VarChar(16)
  metadata                    Json?
  order_index                 Int?                          @default(0) @db.UnsignedInt
  created_at                  DateTime?                     @default(now()) @db.Timestamp(0)
  updated_at                  DateTime?                     @default(now()) @db.Timestamp(0)
  assignment_question_media   assignment_question_media[]
  assignment_question_options assignment_question_options[]
  assignments                 assignments                   @relation(fields: [assignment_id], references: [id], onDelete: Cascade, map: "assignment_questions_ibfk_1")
  assignment_passages         assignment_passages?          @relation(fields: [passage_id], references: [id], map: "assignment_questions_ibfk_2")
  exam_items                  exam_items[]

  @@index([assignment_id], map: "idx_aq_assignment")
  @@index([passage_id], map: "idx_aq_passage")
}

model assignment_submissions {
  id                                                  BigInt                         @id @default(autoincrement()) @db.UnsignedBigInt
  assignment_id                                       BigInt                         @db.UnsignedBigInt
  class_id                                            BigInt?                        @db.UnsignedBigInt
  student_user_id                                     BigInt                         @db.UnsignedBigInt
  attempt_no                                          Int?                           @default(1) @db.UnsignedInt
  status                                              assignment_submissions_status? @default(submitted)
  submitted_at                                        DateTime?                      @db.Timestamp(0)
  graded_at                                           DateTime?                      @db.Timestamp(0)
  graded_by                                           BigInt?                        @db.UnsignedBigInt
  score                                               Decimal?                       @db.Decimal(6, 2)
  feedback                                            String?                        @db.Text
  created_at                                          DateTime?                      @default(now()) @db.Timestamp(0)
  updated_at                                          DateTime?                      @default(now()) @db.Timestamp(0)
  classes                                             classes?                       @relation(fields: [class_id], references: [id], map: "assignment_submissions_ibfk_1")
  users_assignment_submissions_student_user_idTousers users                          @relation("assignment_submissions_student_user_idTousers", fields: [student_user_id], references: [id], onDelete: Cascade, map: "assignment_submissions_ibfk_2")
  users_assignment_submissions_graded_byTousers       users?                         @relation("assignment_submissions_graded_byTousers", fields: [graded_by], references: [id], map: "assignment_submissions_ibfk_3")
  assignments                                         assignments                    @relation(fields: [assignment_id], references: [id], onDelete: Cascade, map: "assignment_submissions_ibfk_4")
  rubric_scores                                       rubric_scores[]
  submission_feedback                                 submission_feedback[]
  submission_files                                    submission_files[]

  @@unique([assignment_id, student_user_id, attempt_no], map: "uk_submission_unique")
  @@index([class_id], map: "class_id")
  @@index([graded_by], map: "graded_by")
  @@index([assignment_id], map: "idx_asgsub_assignment")
  @@index([student_user_id], map: "idx_asgsub_student")
}

model assignment_tags {
  assignment_id BigInt      @db.UnsignedBigInt
  tag_id        BigInt      @db.UnsignedBigInt
  assignments   assignments @relation(fields: [assignment_id], references: [id], onDelete: Cascade, map: "assignment_tags_ibfk_1")
  tags          tags        @relation(fields: [tag_id], references: [id], onDelete: Cascade, map: "assignment_tags_ibfk_2")

  @@id([assignment_id, tag_id])
  @@index([tag_id], map: "tag_id")
}

model assignments {
  id                                  BigInt                         @id @default(autoincrement()) @db.UnsignedBigInt
  tenant_id                           BigInt                         @db.UnsignedBigInt
  title                               String                         @db.VarChar(255)
